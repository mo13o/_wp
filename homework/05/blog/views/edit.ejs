<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <title>編輯文章 - 簡易網誌</title>
  <style>
    body { font-family: sans-serif; max-width: 800px; margin: 0 auto; padding: 20px; }
    h1 { color: #333; }
    label { display: block; margin-top: 15px; font-weight: bold; }
    input, textarea { width: 100%; padding: 8px; margin-top: 5px; border: 1px solid #ddd; border-radius: 4px; box-sizing: border-box; }
    textarea { height: 300px; }
    .btn { display: inline-block; padding: 10px 20px; background: #2c6b9e; color: #fff; border: none; border-radius: 4px; cursor: pointer; margin-top: 15px; }
    .btn:hover { background: #1a4a6e; }
    .cancel { margin-left: 10px; color: #888; }
  </style>
</head>
<body>
  <h1>編輯文章</h1>
  <form action="/post/<%= post.id %>/update" method="POST">
    <label>標題</label>
    <input type="text" name="title" value="<%= post.title %>" required>
    <label>內容</label>
    <textarea name="content" required><%= post.content %></textarea>
    <button type="submit" class="btn">儲存</button>
    <a href="/post/<%= post.id %>" class="cancel">取消</a>
  </form>
</body>
</html>
