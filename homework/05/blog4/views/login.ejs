<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <title>登入 - DC Blog</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f5f5f5; color: #333; display: flex; justify-content: center; align-items: center; min-height: 100vh; }
    .auth-card { background: #fff; border-radius: 12px; padding: 40px; width: 360px; box-shadow: 0 2px 12px rgba(0,0,0,.08); }
    .auth-card .logo { display: block; text-align: center; font-size: 24px; font-weight: 700; color: #6b46c1; text-decoration: none; margin-bottom: 8px; }
    .auth-card p { text-align: center; color: #999; font-size: 14px; margin-bottom: 28px; }
    label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 4px; color: #555; }
    input { width: 100%; padding: 10px 12px; border: 1px solid #ddd; border-radius: 8px; font-size: 14px; margin-bottom: 16px; transition: border .2s; }
    input:focus { outline: none; border-color: #6b46c1; box-shadow: 0 0 0 3px rgba(107,70,193,.1); }
    .btn-primary { width: 100%; background: #6b46c1; color: #fff; border: none; padding: 10px; border-radius: 20px; font-size: 15px; cursor: pointer; transition: background .2s; }
    .btn-primary:hover { background: #553c9a; }
    .link { display: block; text-align: center; margin-top: 16px; color: #999; font-size: 14px; }
    .link a { color: #6b46c1; text-decoration: none; }
    .link a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <div class="auth-card">
    <a href="/" class="logo">DC Blog</a>
    <p>登入你的帳號</p>
    <form action="/login" method="POST">
      <label>帳號</label>
      <input type="text" name="username" required>
      <label>密碼</label>
      <input type="password" name="password" required>
      <button type="submit" class="btn-primary">登入</button>
    </form>
    <div class="link">還沒有帳號？<a href="/register">註冊</a></div>
  </div>
</body>
</html>
